{
    "name": "papaedu/extension",
    "description": "Papaedu extension.",
    "license": "MIT",
    "authors": [
        {
            "name": "Pipi Zhang",
            "email": "zhangpipi.o3o@gmail.com"
        }
    ],
    "require": {
        "php": ">=7",
        "ext-openssl": "*",
        "bensampo/laravel-enum": "^1.35",
        "biubiujun/qcloud": "^1.0",
        "james-heinrich/getid3": "^1.9",
        "overtrue/easy-sms": "^1.1",
        "zgldh/qiniu-laravel-storage": "^0.10"
    },
    "require-dev": {
        "laravel/framework": "^7.0",
        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "Papaedu\\Extension\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Papaedu\\Extension\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Papaedu\\Extension\\Providers\\EnumServiceProvider",
                "Papaedu\\Extension\\Providers\\RuleServiceProvider",
                "Papaedu\\Extension\\Providers\\ChannelServiceProvider"
            ],
            "aliases": {
                "Geetest": "Papaedu\\Extension\\Facades\\Geetest"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs -p --standard=psr12 src/",
        "fix-style": "phpcbf -p --standard=psr12 src/"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
